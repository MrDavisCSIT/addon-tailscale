{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:base"
  ],
  "prHeader": "ADCM-Bot-Header",
  "assignees": [
    "mrdaviscsit"
  ],
  "labels": ["dependencies-updater"],
    "packageRules": [
    {
      "description": "Automerge non-major updates",
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    },
          {
      "matchPackageNames": ["tailscale"],
      "changelogUrl": "https://tailscale.com/changelog"
    }
  ]
}
